# Copy this file to .env and fill in your values

# ─── Google / Vertex AI (required for LLM) ───────────────────────────────────
# Create a service account at console.cloud.google.com → IAM → Service Accounts
# Path to the downloaded GCP service-account JSON file
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
# Your GCP project ID (visible in the GCP console header)
GCP_PROJECT_ID=your-gcp-project-id
# GCP region for Vertex AI endpoints
GCP_REGION=us-central1

# ─── Model Selection ─────────────────────────────────────────────────────────
# LLM for agent reasoning — Google Gemini via Vertex AI
# Options: gemini-2.0-flash, gemini-1.5-pro, gemini-1.5-flash
VERTEX_MODEL=gemini-2.0-flash

# Embedding model for vector similarity search (runs locally, no API key needed)
EMBEDDING_MODEL=text-embedding-005

# ─── News APIs (at least one required) ──────────────────────────────────────
# Primary news source — required; free tier at newsapi.org (100 req/day)
NEWS_API_KEY=your_newsapi_key_here

# Additional news sources used as fallback when primary is rate-limited (optional)
# Finnhub: finnhub.io/register — 60 calls/min on free tier
FINNHUB_API_KEY=
# Alpha Vantage: alphavantage.co/support/#api-key — 500 calls/day on free tier
ALPHAVANTAGE_API_KEY=
# MediaStack: mediastack.com/signup/free — 500 calls/month on free tier
MEDIASTACK_API_KEY=

# ─── Groww API (optional — for fundamentals & live Indian market data) ───────
# JWT token extracted from Groww mobile app (DevTools → Network → Authorization header)
GROWW_API_TOKEN=
# TOTP secret for Groww two-factor authentication (optional, only if 2FA is enabled)
GROWW_TOTP_SECRET=

# ─── DuckDB (analytics store) ────────────────────────────────────────────────
# Relative path from the backend directory; default is fine for local dev
DUCKDB_PATH=market_analytics.duckdb

# ─── Pathway Streaming RAG (optional) ────────────────────────────────────────
# Set to true to activate the live Pathway streaming pipeline.
# When false (default), the app uses the built-in manual RAG fallback instead.
ENABLE_PATHWAY=false
# URL of the Pathway Adaptive RAG server (change only if running on a different host/port)
ADAPTIVE_RAG_URL=http://localhost:8001

# ─── FRED Macro Signals (optional) ──────────────────────────────────────────
# Free API key from fred.stlouisfed.org/docs/api/api_key.html
# Used for macroeconomic indicators: interest rates, CPI, GDP, yield curve
FRED_API_KEY=

# ─── System Configuration ────────────────────────────────────────────────────
# Logging verbosity: debug | info | warning | error
LOG_LEVEL=info
# How often (seconds) the news connector polls for fresh articles
REFRESH_INTERVAL=30
# How often (minutes) the global market data refreshes (WorldMonitor)
GLOBAL_MARKET_REFRESH_MINUTES=15
